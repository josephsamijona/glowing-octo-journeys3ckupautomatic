# ═══════════════════════════════════════════════════════════
# S3 Backup Flow — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════

# --- App ---
APP_ENV=production
SECRET_KEY=generate_a_64_char_hex_secret_here

# --- AWS Cognito (UI authentication) ---
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# --- External API Key (machine-to-machine auth) ---
# Used in X-API-KEY header by Django / FastAPI backends
EXTERNAL_BACKEND_SECRET_TOKEN=generate_a_64_char_hex_secret_here

# --- Database to backup ---
# Supported schemes: mysql:// | postgresql://
DB_URL=mysql://user:password@host:3306/dbname

# --- DynamoDB (task tracking) ---
DynamoDBtable=BackupTasks

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# --- Redis (Railway or self-hosted) ---
REDIS_URL=redis://default:password@host:port
CELERY_BROKER_URL=redis://default:password@host:port

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=backup@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# --- S3 Bucket ---
S3_BUCKET_NAME=your-s3-bucket-name
